{
  "manifest_version": 3,
  "name": "Gapo Auto Tool",
  "version": "2.1.0",
  "permissions": ["scripting", "tabs", "storage"],
  "host_permissions": [
    "https://www.gapowork.vn/*",
    "https://los.tima.vn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.gapowork.vn/*",
        "https://los.tima.vn/loanbrief-search/index.html*"
      ],
      "js": ["utils.js", "popup-ui.js", "page.js", "editor.js", "content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}